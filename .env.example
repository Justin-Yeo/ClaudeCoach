# ClaudeCoach environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# See spec.md §11.2 for the authoritative list.

# --- Database (Supabase Postgres) ---
# Use the POOLED connection string (port 6543), NOT the direct one.
# Format: postgresql+psycopg://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+psycopg://user:password@host:6543/postgres

# --- Strava OAuth + webhook ---
# From https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
# Any random string you make up. Used to verify Strava webhook subscription challenges.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(24))"
STRAVA_WEBHOOK_VERIFY_TOKEN=

# --- Telegram bot ---
# From @BotFather
TELEGRAM_BOT_TOKEN=

# --- Claude (Anthropic) ---
# From https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Locked at claude-sonnet-4-6 per spec.md §11.4. Overridable for swap without redeploy.
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_OUTPUT_TOKENS=3500

# --- Admin bootstrap ---
# Your own Telegram user ID (NOT username). Find via @userinfobot.
# The first /start from this ID auto-flips is_admin=true and skips the invite-code check.
BOOTSTRAP_ADMIN_TELEGRAM_USER_ID=

# --- Deployment ---
# Public HTTPS URL of this service. Used to build the Strava OAuth redirect URI.
# Local dev: your ngrok URL. Prod: your Render URL.
APP_BASE_URL=https://claudecoach.onrender.com

# --- Logging ---
LOG_LEVEL=INFO
